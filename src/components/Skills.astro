---
---

<section class="section section--alt" id="skills" aria-labelledby="skills-heading">
  <div class="container">
    <div class="reveal-blur" style="margin-bottom:3rem;">
      <p class="section-label">Technológiák</p>
      <h2 id="skills-heading" style="margin-bottom:0;">Amivel dolgozom</h2>
    </div>

    <div class="cin-divider" aria-hidden="true"></div>

    <div class="services__list">
      <div class="service-row reveal-left cin-delay-1">
        <span class="service-row__num">01</span>
        <div>
          <div class="service-row__title">Nyelvek</div>
          <p style="font-size:0.82rem;color:var(--text-muted);margin-top:0.2rem;">
            JavaScript · Python · Java · SQL · PHP · HTML · CSS
          </p>
        </div>
        <span class="service-row__arrow">—</span>
      </div>

      <div class="service-row reveal-left cin-delay-2">
        <span class="service-row__num">02</span>
        <div>
          <div class="service-row__title">Frontend</div>
          <p style="font-size:0.82rem;color:var(--text-muted);margin-top:0.2rem;">
            Reszponzív UI · Modern design · Mobilbarát fejlesztés
          </p>
        </div>
        <span class="service-row__arrow">—</span>
      </div>

      <div class="service-row reveal-left cin-delay-3">
        <span class="service-row__num">03</span>
        <div>
          <div class="service-row__title">Backend & Adatbázis</div>
          <p style="font-size:0.82rem;color:var(--text-muted);margin-top:0.2rem;">
            Supabase · XAMPP (MySQL/PHP) · Auth · REST API
          </p>
        </div>
        <span class="service-row__arrow">—</span>
      </div>

      <div class="service-row reveal-left cin-delay-4">
        <span class="service-row__num">04</span>
        <div>
          <div class="service-row__title">Eszközök & DevOps</div>
          <p style="font-size:0.82rem;color:var(--text-muted);margin-top:0.2rem;">
            VS Code · IntelliJ IDEA · Git · Vercel (deploy, CI/CD) · MI-eszközök
          </p>
        </div>
        <span class="service-row__arrow">—</span>
      </div>

      <div class="service-row reveal-left cin-delay-5">
        <span class="service-row__num">05</span>
        <div>
          <div class="service-row__title">Tesztelés</div>
          <p style="font-size:0.82rem;color:var(--text-muted);margin-top:0.2rem;">
            Funkcionális és kézi tesztelés · Tesztdokumentáció · Hibák reprodukálása és javítása
          </p>
        </div>
        <span class="service-row__arrow">—</span>
      </div>
    </div>
  </div>
</section>
