---
---

<section class="section" id="experience" aria-labelledby="exp-heading">
  <div class="container">
    <div class="section-header reveal-blur">
      <div class="section-tag">Tapasztalat</div>
      <h2 id="exp-heading" class="section-title">
        Amit <span>eddig csináltam</span>
      </h2>
    </div>

    <div class="portfolio__grid">
      <article class="portfolio-card reveal-scale cin-delay-1">
        <div class="portfolio-card__image" role="img" aria-label="Freelance webfejlesztés">
          <span style="font-family:var(--font-display);font-size:2rem;font-weight:900;color:var(--text-muted);opacity:0.35;letter-spacing:-0.05em;">01</span>
        </div>
        <div class="portfolio-card__body">
          <h3 class="portfolio-card__title">Freelance webfejlesztés</h3>
          <p class="portfolio-card__desc">
            Laguna Lovasklub — teljes weboldal tervezése, fejlesztése és élesítése.
            Frontend, backend (Supabase), deploy Vercelen. Önálló végigvitel a megrendeléstől az átadásig.
          </p>
          <div class="portfolio-card__tech">
            <span class="badge">JavaScript</span>
            <span class="badge">Supabase</span>
            <span class="badge">Vercel</span>
          </div>
          <span class="portfolio-card__link" style="color:var(--accent);cursor:default;">2022 – napjainkig</span>
        </div>
      </article>

      <article class="portfolio-card reveal-scale cin-delay-2">
        <div class="portfolio-card__image" role="img" aria-label="Saját projektek">
          <span style="font-family:var(--font-display);font-size:2rem;font-weight:900;color:var(--text-muted);opacity:0.35;letter-spacing:-0.05em;">02</span>
        </div>
        <div class="portfolio-card__body">
          <h3 class="portfolio-card__title">Saját & iskolai projektek</h3>
          <p class="portfolio-card__desc">
            Több full-stack webalkalmazás fejlesztése — frontend, adatbázis, deploy.
            Verziókezelés, iteratív fejlesztés, MI-asszisztált kódolási munkafolyamatok.
          </p>
          <div class="portfolio-card__tech">
            <span class="badge">Python</span>
            <span class="badge">Java</span>
            <span class="badge">SQL</span>
            <span class="badge">Git</span>
          </div>
          <span class="portfolio-card__link" style="color:var(--accent);cursor:default;">Full-stack projektek</span>
        </div>
      </article>

      <article class="portfolio-card reveal-scale cin-delay-3">
        <div class="portfolio-card__image" role="img" aria-label="Tesztelés">
          <span style="font-family:var(--font-display);font-size:2rem;font-weight:900;color:var(--text-muted);opacity:0.35;letter-spacing:-0.05em;">03</span>
        </div>
        <div class="portfolio-card__body">
          <h3 class="portfolio-card__title">Szoftvertesztelés</h3>
          <p class="portfolio-card__desc">
            Funkcionális és kézi tesztelés, tesztesetek megírása, hibák reprodukálása
            és dokumentálása. A minőségbiztosítás a fejlesztés szerves része.
          </p>
          <div class="portfolio-card__tech">
            <span class="badge">Tesztdokumentáció</span>
            <span class="badge">Hibakövetés</span>
            <span class="badge">QA</span>
          </div>
          <span class="portfolio-card__link" style="color:var(--accent);cursor:default;">Szakirány: tesztelő</span>
        </div>
      </article>

      <article class="portfolio-card reveal-scale cin-delay-4">
        <div class="portfolio-card__image" role="img" aria-label="Tanulmányok">
          <span style="font-family:var(--font-display);font-size:2rem;font-weight:900;color:var(--text-muted);opacity:0.35;letter-spacing:-0.05em;">04</span>
        </div>
        <div class="portfolio-card__body">
          <h3 class="portfolio-card__title">Tanulmányok</h3>
          <p class="portfolio-card__desc">
            TSZC Bánki Donát – Péch Antal Technikum. Informatika és távközlés ágazat,
            szoftverfejlesztő és -tesztelő szakirány. 4,5-ös átlag.
          </p>
          <div class="portfolio-card__tech">
            <span class="badge">Informatika</span>
            <span class="badge">5. év</span>
            <span class="badge">4,5 átlag</span>
          </div>
          <span class="portfolio-card__link" style="color:var(--accent);cursor:default;">Végzős tanuló</span>
        </div>
      </article>
    </div>
  </div>
</section>
