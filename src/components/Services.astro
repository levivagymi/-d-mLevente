---
---

<section class="section section--alt" id="services" aria-labelledby="services-heading">
  <div class="container">
    <div class="reveal-blur" style="display:flex;align-items:flex-end;justify-content:space-between;gap:2rem;margin-bottom:3rem;flex-wrap:wrap;">
      <div>
        <p class="section-label">Szolgáltatások</p>
        <h2 id="services-heading" style="margin-bottom:0;">Mivel tudok segíteni?</h2>
      </div>
      <a href="#contact" class="btn btn-outline">Ingyenes konzultáció</a>
    </div>

    <div class="cin-divider" aria-hidden="true"></div>

    <div class="services__list">
      <div class="service-row reveal-left cin-delay-1">
        <span class="service-row__num">01</span>
        <div>
          <div class="service-row__title">Weboldal fejlesztés</div>
          <p style="font-size:0.82rem;color:var(--text-muted);margin-top:0.2rem;">
            Egyedi, reszponzív weboldalak – gyors betöltés, modern design, valódi üzleti eredmény.
          </p>
        </div>
        <span class="service-row__price">150 000 Ft-tól</span>
        <span class="service-row__arrow">—</span>
      </div>

      <div class="service-row reveal-left cin-delay-2">
        <span class="service-row__num">02</span>
        <div>
          <div class="service-row__title">Webshop fejlesztés</div>
          <p style="font-size:0.82rem;color:var(--text-muted);margin-top:0.2rem;">
            Egyedi webshopok Stripe vagy Barion fizetéssel, admin felülettel, email értesítésekkel.
          </p>
        </div>
        <span class="service-row__price">350 000 Ft-tól</span>
        <span class="service-row__arrow">—</span>
      </div>

      <div class="service-row reveal-left cin-delay-3">
        <span class="service-row__num">03</span>
        <div>
          <div class="service-row__title">SEO optimalizálás</div>
          <p style="font-size:0.82rem;color:var(--text-muted);margin-top:0.2rem;">
            Technikai és tartalmi SEO – kulcsszókutatás, Core Web Vitals, Schema.org markup.
          </p>
        </div>
        <span class="service-row__price">80 000 Ft-tól</span>
        <span class="service-row__arrow">—</span>
      </div>

      <div class="service-row reveal-left cin-delay-4">
        <span class="service-row__num">04</span>
        <div>
          <div class="service-row__title">Karbantartás &amp; support</div>
          <p style="font-size:0.82rem;color:var(--text-muted);margin-top:0.2rem;">
            Havi csomag: frissítések, mentések, teljesítménymonitorozás, kisebb módosítások.
          </p>
        </div>
        <span class="service-row__price">25 000 Ft/hó</span>
        <span class="service-row__arrow">—</span>
      </div>
    </div>
  </div>
</section>
