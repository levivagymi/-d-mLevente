---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { projects } from '../../data/projects';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Ádám Levente',
  jobTitle: 'Web Developer',
  description: 'Custom website and webshop development for businesses – modern tech, fast loading.',
  url: 'https://adamlevente.hu',
  email: 'adam@adamlevente.hu',
  address: { '@type': 'PostalAddress', addressCountry: 'HU' },
  knowsAbout: ['Web Development', 'SEO', 'Vue.js', 'Nuxt', 'Astro', 'React', 'TypeScript'],
};
---

<Layout
  title="Ádám Levente – Web Developer | Website & Webshop Development"
  description="Custom website and webshop development for businesses. Fast, mobile-friendly, SEO-optimized solutions with modern technologies. Free consultation!"
  canonical="https://adamlevente.hu/en/"
  lang="en"
  schema={personSchema}
>
  <Header lang="en" />
  <main id="main-content">
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <div class="hero__inner">
          <div class="hero__content">
            <div class="hero__tag">
              <span class="hero__tag-dot"></span>
              Available for new projects
            </div>
            <h1 class="hero__title">Ádám <span class="hero__title-accent">Levente</span></h1>
            <p class="hero__subtitle">Web Developer &amp; SEO Specialist</p>
            <p class="hero__desc">
              Custom <strong>website and webshop development</strong> for businesses.
              Fast, mobile-friendly, SEO-optimized solutions built with
              Vue.js, Nuxt, Astro and React.
            </p>
            <div class="hero__buttons">
              <a href="#contact" class="btn btn-primary">Free Consultation →</a>
              <a href="#portfolio" class="btn btn-outline">View Portfolio</a>
            </div>
            <div class="hero__tech">
              <span class="hero__tech-label">Tech stack:</span>
              <span class="badge">Vue.js</span>
              <span class="badge">Nuxt</span>
              <span class="badge">Astro</span>
              <span class="badge">React</span>
              <span class="badge">TypeScript</span>
            </div>
          </div>
          <div class="hero__card" aria-hidden="true">
            <div class="hero__avatar">ÁL</div>
            <div style="font-size:1.1rem;font-weight:700;margin-bottom:0.25rem;">Ádám Levente</div>
            <div style="font-size:0.88rem;color:var(--text-muted);margin-bottom:1.5rem;">Freelance Web Developer</div>
            <div class="hero__services-list">
              <div class="hero__service-item"><span class="hero__service-dot"></span>Website Development</div>
              <div class="hero__service-item"><span class="hero__service-dot"></span>Webshop Development</div>
              <div class="hero__service-item"><span class="hero__service-dot"></span>SEO Optimization</div>
              <div class="hero__service-item"><span class="hero__service-dot"></span>Maintenance &amp; Support</div>
            </div>
            <div class="hero__stat-grid">
              <div class="hero__stat"><div class="hero__stat-num">5</div><div class="hero__stat-label">years experience</div></div>
              <div class="hero__stat"><div class="hero__stat-num">30</div><div class="hero__stat-label">projects done</div></div>
              <div class="hero__stat"><div class="hero__stat-num">98</div><div class="hero__stat-label">% satisfaction</div></div>
              <div class="hero__stat"><div class="hero__stat-num">20</div><div class="hero__stat-label">happy clients</div></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="section section--alt" id="services" aria-labelledby="services-en">
      <div class="container">
        <div class="section-header">
          <div class="section-tag">Services</div>
          <h2 id="services-en" class="section-title">How can I <span>help you</span>?</h2>
        </div>
        <div class="services__grid">
          {[
            { icon: '01', title: 'Website Development', desc: 'Custom, responsive websites. Fast loading, modern design, mobile-friendly.', features: ['Custom design & development', 'Responsive (mobile-first)', 'Basic SEO optimization', 'CMS integration (optional)'] },
            { icon: '02', title: 'Webshop Development', desc: 'Custom e-commerce with Stripe or PayPal. Product management, inventory, orders.', features: ['Custom webshop (Vue/Next.js)', 'Stripe / PayPal payments', 'Admin panel', 'Email notifications'] },
            { icon: '03', title: 'SEO Optimization', desc: 'Technical and content SEO to rank higher in Google search results.', features: ['Technical SEO audit', 'Meta tags & Schema.org', 'Core Web Vitals fix', 'Google Search Console'] },
            { icon: '04', title: 'Maintenance & Support', desc: 'Monthly maintenance: updates, backups, performance monitoring and small changes.', features: ['Regular updates', 'Automated backups', 'Performance monitoring', 'Priority support'] },
          ].map((svc) => (
            <div class="service-card">
              <div class="service-card__icon">{svc.icon}</div>
              <h3 class="service-card__title">{svc.title}</h3>
              <p class="service-card__desc">{svc.desc}</p>
              <ul class="service-card__features">
                {svc.features.map((f) => <li class="service-card__feature">{f}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Portfolio -->
    <section class="section" id="portfolio" aria-labelledby="portfolio-en">
      <div class="container">
        <div class="section-header">
          <div class="section-tag">Portfolio</div>
          <h2 id="portfolio-en" class="section-title">Recent <span>projects</span></h2>
        </div>
        <div class="portfolio__grid">
          {projects.map((project) => (
            <article class="portfolio-card">
              <div class="portfolio-card__image" role="img" aria-label={project.altText}>
                <span style="font-family:var(--font-display);font-size:2rem;font-weight:900;color:var(--text-muted);opacity:0.3;letter-spacing:-0.05em;">{projects.indexOf(project) + 1}</span>
              </div>
              <div class="portfolio-card__body">
                <h3 class="portfolio-card__title">{project.title}</h3>
                <p class="portfolio-card__desc">{project.description}</p>
                <div class="portfolio-card__tech">
                  {project.tech.map((t) => <span class="badge">{t}</span>)}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="section section--alt" id="contact" aria-labelledby="contact-en">
      <div class="container">
        <div class="contact__inner">
          <div class="contact__info">
            <div class="section-tag">Contact</div>
            <h2 id="contact-en">Let's work <span style="color:var(--accent)">together</span>!</h2>
            <p>Have a project idea or a question? Feel free to reach out! I usually respond within 24 hours and offer a free consultation to all inquiries.</p>
            <div class="contact__detail">
              <div class="contact__detail-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
              </div>
              <div>
                <div class="contact__detail-label">Email</div>
                <a href="mailto:adam@adamlevente.hu" class="contact__detail-value">adam@adamlevente.hu</a>
              </div>
            </div>
            <div class="contact__detail">
              <div class="contact__detail-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <div class="contact__detail-label">Location</div>
                <div class="contact__detail-value">Hungary (remote available)</div>
              </div>
            </div>
          </div>
          <div class="form">
            <form aria-label="Contact form" id="contact-form-en" action="#" method="POST">
              <div class="form__honeypot" aria-hidden="true">
                <label for="hp-en">Do not fill</label>
                <input type="text" id="hp-en" name="hp_field" tabindex="-1" autocomplete="off" />
              </div>
              <div class="form__grid">
                <div class="form__group">
                  <label class="form__label" for="en-name">Your name *</label>
                  <input class="form__input" type="text" id="en-name" name="name" required autocomplete="name" placeholder="John Doe" />
                </div>
                <div class="form__group">
                  <label class="form__label" for="en-email">Email *</label>
                  <input class="form__input" type="email" id="en-email" name="email" required autocomplete="email" placeholder="john@example.com" />
                </div>
              </div>
              <div class="form__group">
                <label class="form__label" for="en-message">Message *</label>
                <textarea class="form__textarea" id="en-message" name="message" required placeholder="Tell me about your project..."></textarea>
              </div>
              <button type="submit" class="btn btn-primary form__submit">Send message →</button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
