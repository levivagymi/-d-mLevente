---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Főoldal', item: 'https://adamlevente.hu/' },
    { '@type': 'ListItem', position: 2, name: 'Árak', item: 'https://adamlevente.hu/arak/' },
  ],
};

const categories = [
  {
    title: 'Alap csomag',
    modules: [
      { id: 'alap', name: 'Egyedi weboldal (1–3 oldal, mobilbarát, reszponzív)', price: 150000, preset: true, info: 'Minden projekt alapja: egyedi design, reszponzív kialakítás, alapszintű SEO, contact form, deployment.' },
    ],
  },
  {
    title: 'Oldalak & Tartalom',
    modules: [
      { id: 'pages-sm',   name: 'Bővített oldalszám (3–5 oldal)',         price: 25000,  preset: false, info: 'Az alap 1–3 oldal mellé további 2 aloldal fejlesztése.' },
      { id: 'pages-md',   name: 'Komplett struktúra (5–10 oldal)',         price: 55000,  preset: false, info: '5–10 teljesen egyedi aloldal, saját tartalom-struktúrával.' },
      { id: 'pages-lg',   name: 'Nagy weboldal (10–20 oldal)',             price: 100000, preset: false, info: 'Kiterjedt oldalhierarchia, kategorizált tartalom, belső linkelés.' },
      { id: 'about',      name: 'Bemutatkozó / Rólunk oldal',              price: 20000,  preset: false, info: 'Részletes "Rólunk" oldal csapatbemutatással, értékekkel, történettel.' },
      { id: 'portfolio-p',name: 'Referenciák / Portfólió oldal',          price: 25000,  preset: false, info: 'Filterezhető munkák / projektek oldal, kategóriákkal és modális nézettel.' },
      { id: 'pricing-p',  name: 'Árlista / Csomagok oldal',               price: 30000,  preset: false, info: 'Táblázatos vagy kártyás árösszehasonlítás, kiemelő csomag.' },
      { id: 'faq-p',      name: 'GYIK oldal',                             price: 15000,  preset: false, info: 'Kinyitható GYIK szekció, FAQ schema.org strukturált adatokkal.' },
      { id: 'landing',    name: 'Marketing landing page',                  price: 40000,  preset: false, info: 'Konverzióra optimalizált egyoldalas kampányoldal, A/B teszt ready.' },
      { id: 'gdpr',       name: 'GDPR oldalak (adatvédelem, sütik)',       price: 20000,  preset: false, info: 'Jogi megfelelőség: adatkezelési tájékoztató, süti-szabályzat, impresszum.' },
    ],
  },
  {
    title: 'Funkcionális modulok',
    modules: [
      { id: 'blog',       name: 'Blog szekció (CMS)',                      price: 40000,  preset: false, info: 'Teljes értékű blog CMS-sel – kategóriák, szerzők, RSS feed, keresés.' },
      { id: 'form-adv',   name: 'Haladó kapcsolati form',                  price: 25000,  preset: false, info: 'Spam-védelemmel (Cloudflare Turnstile), email értesítővel, fájlfeltöltéssel.' },
      { id: 'gallery',    name: 'Galéria / képportfólió szekció',          price: 30000,  preset: false, info: 'Lightbox-os filterezhető képgaléria, lazy-load optimalizálással.' },
      { id: 'calc',       name: 'Árkonfigurátor / kalkulátor',             price: 45000,  preset: false, info: 'Interaktív moduláris árkonfigurátor – mint ez az oldal.' },
      { id: 'booking',    name: 'Online időpontfoglaló',                   price: 80000,  preset: false, info: 'Naptáralapú foglalási rendszer email megerősítéssel és admin nézettel.' },
      { id: 'webshop',    name: 'Webshop (Stripe / Barion)',               price: 200000, preset: false, info: 'Termékkezelés, kosár, online fizetés, admin felület, rendeléskövetés.' },
      { id: 'members',    name: 'Tagság / bejelentkezési rendszer',        price: 90000,  preset: false, info: 'Felhasználói regisztráció, bejelentkezés, profil, védett tartalmak.' },
      { id: 'multilang',  name: 'Többnyelvűség (HU + EN)',                 price: 50000,  preset: false, info: 'Teljesen lokalizált felület, URL-alapú nyelvváltás, hreflang tagek.' },
      { id: 'newsletter', name: 'Hírlevél feliratkozó',                    price: 20000,  preset: false, info: 'Feliratkozó form Mailchimp / Brevo integrációval, double opt-in.' },
      { id: 'livechat',   name: 'Élő chat integráció (Tidio / Tawk)',      price: 15000,  preset: false, info: 'Chat widget beágyazása, automatikus üdvözlő üzenet.' },
      { id: 'search',     name: 'Oldalbeli kereső funkció',                price: 35000,  preset: false, info: 'Azonnali teljes szöveges keresés a weboldal tartalmában.' },
      { id: 'reviews',    name: 'Értékelések / Vélemények szekció',        price: 25000,  preset: false, info: 'Google Reviews import vagy saját vélemény-beküldő rendszer.' },
      { id: 'cookie',     name: 'Cookie hozzájáruló panel (GDPR)',         price: 15000,  preset: false, info: 'Testreszabható cookie consent sáv, preferencia-kezeléssel.' },
      { id: 'social',     name: 'Közösségi megosztás gombok',              price: 10000,  preset: false, info: 'Facebook, LinkedIn, X (Twitter) megosztás Open Graph metaadatokkal.' },
      { id: 'popups',     name: 'Pop-up / modal rendszer',                 price: 20000,  preset: false, info: 'Exit-intent popup, hírlevél popup, promóciós modálok.' },
    ],
  },
  {
    title: 'E-commerce bővítmények',
    modules: [
      { id: 'filter',     name: 'Termékszűrő és keresés',                 price: 45000,  preset: false, info: 'Ár, kategória, attribútum alapú szűrő, azonnali találatok.' },
      { id: 'stock',      name: 'Raktárkészlet-kezelés',                  price: 40000,  preset: false, info: 'Valós idejű készletfigyelés, alacsony-készlet értesítő, admin panel.' },
      { id: 'coupon',     name: 'Kuponrendszer és kedvezmények',          price: 35000,  preset: false, info: 'Egyszer használatos / mennyiségi / időkorlátozott kuponok.' },
      { id: 'email-shop', name: 'Tranzakciós emailek (rendelés, szállítás)', price: 30000, preset: false, info: 'Egyedi HTML email sablonok – rendelés visszaigazolás, szállítási értesítő.' },
      { id: 'variants',   name: 'Termékváltozatok (szín, méret, stb.)',   price: 40000,  preset: false, info: 'Kombinálható attribútumok, egyedi árak és képek változatonként.' },
      { id: 'wishlist',   name: 'Wishlist / Kedvencek lista',             price: 25000,  preset: false, info: 'Bejelentkezés nélküli vagy profil-alapú kedvencek mentése.' },
      { id: 'invoice',    name: 'PDF számlagenerálás',                    price: 35000,  preset: false, info: 'Automatikus számlakészítés rendelés után, letölthető PDF formátumban.' },
      { id: 'related',    name: 'Ajánlott termékek modul',               price: 20000,  preset: false, info: 'Kategória / tag alapú keresztértékesítés a termékoldalakon.' },
    ],
  },
  {
    title: 'Design & UX modulok',
    modules: [
      { id: 'anim',       name: 'Egyedi scroll animációk',                price: 35000,  preset: false, info: 'IntersectionObserver alapú belépési animációk, staggerelt megjelenések.' },
      { id: 'darkmode',   name: 'Dark mode',                              price: 20000,  preset: false, info: 'Rendszer- és manuálisan váltható sötét / világos téma, localStorage.' },
      { id: 'logo',       name: 'Logo tervezés',                          price: 40000,  preset: false, info: '3 koncepció, 2 forduló módosítás, SVG + PNG + favicon formátumban.' },
      { id: 'illustr',    name: 'Egyedi illusztrációk',                   price: 50000,  preset: false, info: 'Vektoros egyedi illusztrációk a brand arculatához igazítva.' },
      { id: 'icons',      name: 'Egyedi ikonkészlet',                     price: 30000,  preset: false, info: '20–30 darab egyedi SVG ikon a weboldal stílusához igazítva.' },
      { id: 'videobg',    name: 'Videó háttér (hero szekció)',            price: 25000,  preset: false, info: 'Autoplay, muted, loop videó háttér, fallback képpel.' },
      { id: 'parallax',   name: 'Haladó parallax effektek',               price: 25000,  preset: false, info: 'Többrétegű scroll-parallax, depth hatás, smooth tweenelés.' },
      { id: 'microanim',  name: 'Micro-interakciók',                     price: 20000,  preset: false, info: 'Gomb hover effektek, form visszajelzések, loading state-ek.' },
      { id: 'countdown',  name: 'Visszaszámláló / határidő widget',       price: 15000,  preset: false, info: 'Nap/óra/perc/mp visszaszámláló – kampányokhoz, eseményekhez.' },
      { id: 'loader',     name: 'Betöltési animáció (page loader)',       price: 15000,  preset: false, info: 'Egyedi oldalbetöltési képernyő, brand-konzisztens animációval.' },
    ],
  },
  {
    title: 'Integrációk & API-k',
    modules: [
      { id: 'gmaps',      name: 'Google Maps integráció',                 price: 15000,  preset: false, info: 'Interaktív térkép, egyedi marker, irányok link.' },
      { id: 'ig-feed',    name: 'Instagram feed beágyazás',               price: 20000,  preset: false, info: 'Automatikusan frissülő Instagram galéria szekció.' },
      { id: 'mailchimp',  name: 'Mailchimp / Brevo integráció',           price: 20000,  preset: false, info: 'Kétirányú feliratkozó szinkron, szegmens-kezelés.' },
      { id: 'hubspot',    name: 'HubSpot CRM integráció',                 price: 35000,  preset: false, info: 'Kontakt form adatok automatikus CRM-be küldése, deal létrehozás.' },
      { id: 'zapier',     name: 'Zapier / Make automatizáció',            price: 25000,  preset: false, info: 'Webhook alapú automatizáció, 3rd-party service-ek összekötése.' },
      { id: 'wa-btn',     name: 'WhatsApp chat gomb',                    price: 10000,  preset: false, info: 'Rögzített WhatsApp gomb előre töltött üzenettel.' },
      { id: 'calendly',   name: 'Calendly / Cal.com beágyazás',          price: 15000,  preset: false, info: 'Naptárfoglalás beágyazva, pop-up vagy inline módban.' },
      { id: 'yt',         name: 'YouTube / Vimeo videó szekció',          price: 10000,  preset: false, info: 'Optimalizált videó beágyazás, lazy-load, egyedi thumbnail.' },
      { id: 'paypal',     name: 'PayPal fizetési kapu',                   price: 30000,  preset: false, info: 'PayPal checkout integráció, express gomb, webhook feldolgozás.' },
      { id: 'slack',      name: 'Slack / email értesítők (form → chat)',  price: 15000,  preset: false, info: 'Kapcsolati form beküldések azonnali Slack vagy email értesítővel.' },
      { id: 'ga4',        name: 'Google Analytics 4 + konverziók',       price: 20000,  preset: false, info: 'GA4 setup, egyedi események, konverziók, eCommerce tracking.' },
    ],
  },
  {
    title: 'SEO & Teljesítmény',
    modules: [
      { id: 'seo-adv',    name: 'Haladó SEO + tartalmi stratégia',       price: 60000,  preset: false, info: 'Kulcsszókutatás, versenytárselemzés, pillar content terv, linképítés.' },
      { id: 'local-seo',  name: 'Lokális SEO (városoldalak)',             price: 40000,  preset: false, info: 'Google Business Profile, városspecifikus landing oldalak, NAP konzisztencia.' },
      { id: 'schema',     name: 'Schema.org struktúrált adatok',          price: 20000,  preset: false, info: 'FAQ, LocalBusiness, Product, Article, BreadcrumbList sémák.' },
      { id: 'cwv',        name: 'Core Web Vitals optimalizálás',          price: 30000,  preset: false, info: 'LCP, CLS, INP javítás, Lighthouse 95+ célpontszám.' },
      { id: 'img-opt',    name: 'Képoptimalizálás (WebP, AVIF, lazy)',    price: 15000,  preset: false, info: 'Modern képformátumok, responsive srcset, automatikus tömörítés.' },
      { id: 'cdn',        name: 'CDN beállítás (Cloudflare)',             price: 20000,  preset: false, info: 'Cloudflare proxy, cache rules, page rules, image optimization.' },
      { id: 'heatmap',    name: 'Heatmap integráció (Hotjar / MS Clarity)', price: 15000, preset: false, info: 'Kattintási és scroll heatmap, session recording beállítás.' },
      { id: 'sitemap-r',  name: 'XML Sitemap + robots.txt konfiguráció', price: 10000,  preset: false, info: 'Automatikusan frissülő sitemap, crawler direktívák, GSC bekülsdés.' },
      { id: 'og',         name: 'Open Graph / Twitter Card beállítás',   price: 10000,  preset: false, info: 'Minden oldalhoz egyedi OG kép, title, description, Twitter card.' },
    ],
  },
  {
    title: 'Technológia & Infrastruktúra',
    modules: [
      { id: 'pwa',        name: 'PWA (Progressive Web App)',              price: 40000,  preset: false, info: 'Offline működés, telepíthető app, push értesítők, service worker.' },
      { id: 'ssr',        name: 'Szerver-oldali renderelés (SSR/SSG)',    price: 30000,  preset: false, info: 'Next.js / Nuxt SSR vagy statikus generálás, ISR támogatással.' },
      { id: 'api',        name: 'REST API fejlesztés',                    price: 60000,  preset: false, info: 'Egyedi backend API végpontok, autentikáció, rate limiting.' },
      { id: 'db',         name: 'Adatbázis tervezés és setup',            price: 45000,  preset: false, info: 'PostgreSQL / Supabase séma tervezés, migráció, indexek.' },
      { id: 'cicd',       name: 'CI/CD pipeline (auto deploy)',           price: 30000,  preset: false, info: 'GitHub Actions alapú automatikus build és deploy Vercel / Netlify-ra.' },
      { id: 'cache',      name: 'Gyorsítótár (Redis / edge cache)',       price: 25000,  preset: false, info: 'Redis cache vagy edge caching konfiguráció, cache invalidáció.' },
      { id: 'queue',      name: 'Aszinkron feladatsor (Queue)',           price: 35000,  preset: false, info: 'Háttérfeladatok, email küldés, PDF generálás queue rendszerrel.' },
      { id: 'webhook',    name: 'Webhook rendszer',                       price: 20000,  preset: false, info: 'Bejövő/kimenő webhook kezelő, event-alapú integráció.' },
    ],
  },
  {
    title: 'Karbantartás & Biztonság',
    modules: [
      { id: 'maint-3',    name: 'Havi karbantartás (3 hónap)',           price: 75000,  preset: false, info: 'Frissítések, biztonsági ellenőrzés, kisebb módosítások – 3 hónapra.' },
      { id: 'maint-6',    name: 'Havi karbantartás (6 hónap)',           price: 135000, preset: false, info: 'Frissítések, ellenőrzések, módosítások – 6 hónapra (kedvezményesen).' },
      { id: 'backup',     name: 'Automatikus mentés (3 hónap)',          price: 30000,  preset: false, info: 'Napi mentések külső tárhelyre, 30 napos visszaállíthatóság.' },
      { id: 'priority',   name: 'Prioritásos support (60 nap)',           price: 40000,  preset: false, info: '4 órán belüli válasz, elsőbbségi hibajavítás 60 napig.' },
      { id: 'ssl',        name: 'SSL tanúsítvány beállítás',             price: 10000,  preset: false, info: 'HTTPS konfiguráció, automatikus megújítás, HSTS fejlécek.' },
      { id: 'firewall',   name: 'Tűzfal & DDoS védelem',                 price: 20000,  preset: false, info: 'Cloudflare WAF szabályok, bot-szűrés, rate limiting.' },
      { id: 'audit',      name: 'Biztonsági audit',                      price: 35000,  preset: false, info: 'Sérülékenység-vizsgálat, dependency audit, fejléc-ellenőrzés.' },
      { id: 'uptime',     name: 'Uptime monitoring (1 év)',               price: 15000,  preset: false, info: 'Folyamatos elérhetőség-figyelés, SMS/email riasztás leálláskor.' },
      { id: 'gdpr-audit', name: 'GDPR megfelelőség átvilágítás',         price: 25000,  preset: false, info: 'Adatkezelési térkép, DPA dokumentáció, cookie audit, fejlesztési javaslatok.' },
    ],
  },
  {
    title: 'Képzés & Dokumentáció',
    modules: [
      { id: 'train',      name: 'Admin felület oktatás (2 óra, online)',  price: 20000,  preset: false, info: 'Képernyőmegosztással vezérelt oktatás a CMS / admin panel kezeléséről.' },
      { id: 'docs',       name: 'Írott kezelési dokumentáció',            price: 25000,  preset: false, info: 'PDF és online formátumú lépésről lépésre szerkesztői útmutató.' },
      { id: 'video-docs', name: 'Videó tutorial csomag (5 felvétel)',     price: 40000,  preset: false, info: '5 rövid screencast videó az oldal kezeléséhez, Loom / YouTube.' },
      { id: 'handover',   name: 'Projekt átadó dokumentáció',             price: 15000,  preset: false, info: 'Technikai átadó: forráskód leírás, credentials, architektúra ábra.' },
    ],
  },
];

function fmt(n: number) {
  return n.toLocaleString('hu-HU') + ' Ft';
}
---

<Layout
  title="Weboldal készítés árak 2025 | Ádám Levente"
  description="Weboldal és webshop fejlesztés árak 2025-ben. Alap csomag 150 000 Ft-tól – modulárisan bővíthető. Számold ki online az árat, ingyenes konzultáció."
  canonical="https://adamlevente.hu/arak/"
  schema={breadcrumbSchema}
>
  <Header />
  <main id="main-content" style="padding-bottom:6rem;">

    <div class="page-hero">
      <div class="container">
        <nav aria-label="Navigációs útvonal" style="margin-bottom:1.5rem;">
          <ol style="display:flex;align-items:center;gap:0.5rem;list-style:none;font-size:0.83rem;color:var(--text-muted);">
            <li><a href="/" style="color:var(--text-muted);">Főoldal</a></li>
            <li style="color:var(--border);">/</li>
            <li style="color:var(--text);" aria-current="page">Árak</li>
          </ol>
        </nav>
        <p class="section-label">Árkonfigurátor</p>
        <h1>Állítsd össze<br /><em>a saját projektedet.</em></h1>
        <p style="margin-top:1rem;max-width:540px;font-size:1.05rem;">
          Pipáld ki a modulokat, amikre szükséged van, és azonnal látod az indikatív árat.
          10 kategória, 80+ modul – minden igényre van megoldás.
        </p>
      </div>
    </div>

    <section class="section" aria-label="Árkonfigurátor">
      <div class="container">

        <div class="price-header">
          <div>
            <p class="price-header__label">Alap ár (mindig benne)</p>
            <p class="price-header__sub">Egyedi design · mobilbarát · reszponzív · 1–3 oldal · alap SEO · deployment</p>
          </div>
          <div class="price-header__amount">150 000 Ft</div>
        </div>

        {categories.map((cat) => (
          <div class="calc-category">
            <p class="calc-category__title">{cat.title}</p>
            <div class="calc-modules">
              {cat.modules.map((mod) => (
                <div class={`module-item${mod.preset ? ' module-item--preset' : ''}`}>
                  <label class="module-label" for={`mod-${mod.id}`}>
                    <input
                      class="module-check"
                      type="checkbox"
                      id={`mod-${mod.id}`}
                      data-price={mod.price}
                      checked={mod.preset}
                      disabled={mod.preset}
                    />
                    <span class="module-name">{mod.name}</span>
                    <button
                      class="module-info-btn"
                      type="button"
                      title={mod.info}
                      aria-label={`Részletek: ${mod.name}`}
                    >i</button>
                    <span class="module-price">{fmt(mod.price)}</span>
                  </label>
                </div>
              ))}
            </div>
          </div>
        ))}

        <!-- Megjegyzések és feltételek -->
        <div style="margin-top:3rem;display:grid;grid-template-columns:1fr 1fr;gap:1rem;">

          <div style="padding:1.75rem;background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-lg);">
            <p style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--accent);margin-bottom:0.75rem;">Ami nincs benne az árban</p>
            <ul style="list-style:none;display:flex;flex-direction:column;gap:0.5rem;">
              {['Domain és tárhely díja', 'Szövegírás, fordítás', 'Fotózás, képvásárlás (stock)', 'Fizetési kapu tranzakciós díjai', 'Harmadik féltől vásárolt licenszek'].map(item => (
                <li style="font-size:0.83rem;color:var(--text-muted);display:flex;align-items:flex-start;gap:0.5rem;">
                  <span style="color:var(--border);flex-shrink:0;margin-top:2px;">–</span>{item}
                </li>
              ))}
            </ul>
          </div>

          <div style="padding:1.75rem;background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-lg);">
            <p style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--accent);margin-bottom:0.75rem;">Általános feltételek</p>
            <ul style="list-style:none;display:flex;flex-direction:column;gap:0.5rem;">
              {[
                'Az árak nettó összegek (ÁFA nem tartalmaz)',
                'Indikatív árak – végső ár konzultáció után',
                '50% előleg az induláskor, 50% átadáskor',
                'Fizetési határidő: 8 munkanap',
                'Ingyenes konzultáció minden projekthez',
              ].map(item => (
                <li style="font-size:0.83rem;color:var(--text-muted);display:flex;align-items:flex-start;gap:0.5rem;">
                  <span style="color:var(--border);flex-shrink:0;margin-top:2px;">–</span>{item}
                </li>
              ))}
            </ul>
          </div>

        </div>

        <!--
          ÁRAZÁSI MEGJEGYZÉS – BELSŐ DOKUMENTÁCIÓ
          =========================================
          Késöbbi változtatás során az újonnan hozzáadott modulok 1.5× szorzóval lépnek be az alap árukhoz képest.
          Például: ha egy modul jelenlegi ára 30 000 Ft, az újabb verziójában 45 000 Ft-ként jelenik meg.
          Ez biztosítja az inflációkövető, fenntartható árazást anélkül, hogy a meglévő modulokat visszamenőleg kellene módosítani.
          A szorzó nem vonatkozik az alap csomagra (150 000 Ft).
        -->
        <div style="margin-top:1rem;padding:1.75rem;background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-lg);">
          <p style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);margin-bottom:0.6rem;">Megjegyzés a jövőbeni változtatásokhoz</p>
          <p style="font-size:0.83rem;color:var(--text-muted);line-height:1.8;">
            Az árak indikatívak és az adott projekt komplexitásától függhetnek.
            Jövőbeni bővítések során az újonnan bevezetett modulok az aktuális ár <strong style="color:var(--text);">1.5× szorzójával</strong> kerülnek be,
            hogy az inflációt és a megnövekedett komplexitást tükrözzék. A meglévő modulok árait ez nem érinti visszamenőleg.
          </p>
        </div>

      </div>
    </section>

  </main>

  <!-- Sticky price bar -->
  <div class="price-bar" id="price-bar" role="complementary" aria-label="Összesített ár">
    <div class="container">
      <div class="price-bar__inner">
        <div class="price-bar__left">
          <span class="price-bar__label">Becsült összeg</span>
          <span class="price-bar__amount" id="price-total">150 000 Ft</span>
          <span class="price-bar__note">nettó · indikatív</span>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;flex-shrink:0;">
          <span id="price-module-count" style="font-size:0.75rem;color:rgba(240,238,230,0.4);">0 modul kiválasztva</span>
          <a href="/#contact" class="btn btn-primary">Ingyenes konzultáció</a>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script>
  const checkboxes = document.querySelectorAll<HTMLInputElement>('.module-check');
  const totalEl = document.getElementById('price-total');
  const countEl = document.getElementById('price-module-count');

  function calcTotal() {
    let sum = 0;
    let count = 0;
    checkboxes.forEach((cb) => {
      if (cb.checked) {
        sum += parseInt(cb.dataset.price || '0', 10);
        if (!cb.disabled) count++;
      }
    });
    return { sum, count };
  }

  function formatHU(n: number) {
    return n.toLocaleString('hu-HU') + ' Ft';
  }

  function updateTotal() {
    const { sum, count } = calcTotal();
    if (totalEl) totalEl.textContent = formatHU(sum);
    if (countEl) countEl.textContent = count === 0 ? '0 modul kiválasztva' : `${count} modul kiválasztva`;
  }

  checkboxes.forEach((cb) => {
    if (!cb.disabled) {
      cb.addEventListener('change', updateTotal);
    }
  });

  // Info tooltip
  document.querySelectorAll<HTMLButtonElement>('.module-info-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const tip = btn.title;
      if (tip) alert(tip);
    });
  });

  updateTotal();
</script>
