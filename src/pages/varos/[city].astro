---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { cities, getCityBySlug } from '../../data/cities';

export function getStaticPaths() {
  return cities.map((city) => ({
    params: { city: city.slug },
  }));
}

const { city: citySlug } = Astro.params;
const cityData = getCityBySlug(citySlug);

if (!cityData) {
  return Astro.redirect('/404/');
}

const localBizSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: `Ádám Levente – Honlapkészítés ${cityData.name}`,
  description: `Egyedi weboldal és webshop fejlesztés ${cityData.nameIn} vállalkozásoknak. Gyors, SEO-optimalizált megoldások modern technológiákkal.`,
  url: `https://adamlevente.hu/varos/${cityData.slug}/`,
  email: 'adam@adamlevente.hu',
  priceRange: '$$',
  areaServed: {
    '@type': 'City',
    name: cityData.name,
    containedInPlace: {
      '@type': 'AdministrativeArea',
      name: cityData.region,
    },
  },
  knowsAbout: ['Webfejlesztés', 'SEO', 'Webshop fejlesztés'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Webfejlesztési szolgáltatások',
    itemListElement: [
      { '@type': 'Offer', name: 'Weboldal készítés', price: '120000', priceCurrency: 'HUF' },
      { '@type': 'Offer', name: 'Webshop fejlesztés', price: '450000', priceCurrency: 'HUF' },
    ],
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Főoldal', item: 'https://adamlevente.hu/' },
    { '@type': 'ListItem', position: 2, name: `Honlapkészítés ${cityData.name}`, item: `https://adamlevente.hu/varos/${cityData.slug}/` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `Mennyibe kerül egy weboldal ${cityData.nameIn}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Egy bemutatkozó weboldal ára ${cityData.nameIn} 120 000 Ft-tól indul. Az üzleti weboldal 280 000 Ft-tól, a webshop fejlesztés 450 000 Ft-tól érhető el. Minden projekt ingyenes konzultációval indul.`,
      },
    },
    {
      '@type': 'Question',
      name: `Mennyi idő alatt készül el a weboldal ${cityData.nameIn}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Egy átlagos bemutatkozó weboldal 1–2 hét alatt elkészül. Komplexebb webshopnál 3–6 héttel kell számolni. A pontos határidőt az ingyenes konzultáción egyeztetjük.`,
      },
    },
  ],
};
---

<Layout
  title={`Honlapkészítés ${cityData.name} 2025 – Ádám Levente Webfejlesztő`}
  description={`Honlapkészítés ${cityData.nameIn} – egyedi, SEO-optimalizált weboldal és webshop fejlesztés ${cityData.name}i vállalkozásoknak. 120 000 Ft-tól. Ingyenes konzultáció!`}
  canonical={`https://adamlevente.hu/varos/${cityData.slug}/`}
  schema={[localBizSchema, breadcrumbSchema, faqSchema]}
>
  <Header />
  <main id="main-content">

    <!-- City Hero -->
    <div class="city-hero">
      <div class="container">
        <nav aria-label="Navigációs útvonal">
          <p class="city-hero__breadcrumb">
            <a href="/">Főoldal</a> / <a href="/varos/">Városok</a> / Honlapkészítés {cityData.name}
          </p>
        </nav>
        <div class="city-hero__tag">{cityData.region}</div>
        <h1>Honlapkészítés {cityData.name} –<br />Egyedi weboldal fejlesztés</h1>
        <p style="font-size:1.1rem;color:var(--text-muted);margin-top:1.25rem;max-width:620px;line-height:1.8;">
          Webfejlesztőként {cityData.nameIn} és az egész {cityData.region}ban segítek
          egyedi, keresőoptimalizált weboldalakat és webshopokat készíteni
          – gyorsan, átláthatóan, betartott határidőkkel.
        </p>
        <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
          <a href="/#contact" class="btn btn-primary">Ingyenes konzultáció kérése →</a>
          <a href="/arak/" class="btn btn-outline">Árak megtekintése</a>
        </div>

        <!-- Quick stats -->
        <div style="display:flex;gap:2rem;margin-top:3rem;flex-wrap:wrap;">
          <div>
            <div style="font-family:var(--font-display);font-size:1.75rem;font-weight:900;color:var(--accent);line-height:1;">120 000 Ft</div>
            <div style="font-size:0.8rem;color:var(--text-muted);margin-top:4px;">-tól induló ár</div>
          </div>
          <div>
            <div style="font-family:var(--font-display);font-size:1.75rem;font-weight:900;color:var(--accent);line-height:1;">1–2 hét</div>
            <div style="font-size:0.8rem;color:var(--text-muted);margin-top:4px;">átlagos átfutás</div>
          </div>
          <div>
            <div style="font-family:var(--font-display);font-size:1.75rem;font-weight:900;color:var(--accent);line-height:1;">24 óra</div>
            <div style="font-size:0.8rem;color:var(--text-muted);margin-top:4px;">válaszidő</div>
          </div>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="city-content">

        <h2>Weboldal készítés {cityData.nameIn} – miért érdemes engem választani?</h2>
        <p>
          Ha {cityData.name}i vállalkozásodnak szeretnél modern, gyors és keresőoptimalizált
          weboldalt, jó helyen jársz. Freelance webfejlesztőként közel 5 éve segítem
          a {cityData.region}i és az egész magyarországi vállalkozásokat abban, hogy
          az interneten is sikeresen mutassák be magukat.
        </p>
        <p>
          Minden elkészített weboldal alapból mobilbarát (reszponzív), gyorsan töltődik be,
          és tartalmazza az alapszintű <strong>SEO optimalizálást</strong> – meta tagek,
          strukturált adatok, sitemap, robots.txt. Így weboldalad nemcsak szép lesz,
          hanem a Google is megtalálja.
        </p>

        <h2>Mit kínálok {cityData.name}i vállalkozásoknak?</h2>
        <ul>
          <li>Egyedi weboldal fejlesztés – Vue.js, Nuxt, Astro és React alapon</li>
          <li>Webshop fejlesztés Stripe vagy Barion fizetési integrációval</li>
          <li>SEO optimalizálás – helyi és országos keresések lefedésére</li>
          <li>CMS integráció – önállóan szerkeszthető tartalmak</li>
          <li>Havi karbantartás és support csomagok</li>
          <li>Google Analytics és Search Console beállítás</li>
          <li>Cloudflare integráció – biztonság és sebesség</li>
        </ul>

        <h2>Honlapkészítés árak {cityData.nameIn}</h2>
        <p>
          Az árak átláthatóak és rugalmasak. Egy egyszerű bemutatkozó weboldal
          <strong>120 000 Ft-tól</strong> indul, míg egy komplett üzleti weboldal
          CMS-szel <strong>280 000 Ft-tól</strong> érhető el. Webshop fejlesztés
          esetén az ár <strong>450 000 Ft-tól</strong> kezdődik.
          Minden projekt ingyenes konzultációval indul.
        </p>

        <h2>Milyen vállalkozásoknak tudok segíteni {cityData.nameIn}?</h2>
        <p>
          Szívesen dolgozom együtt minden iparágban tevékenykedő vállalkozással:
          éttermek, szépségszalonok, fogorvosok, ügyvédek, könyvelők, autószerelők,
          fitnesz stúdiók, ingatlanügynökségek – bármilyen vállalkozásnak, amelynek
          szüksége van professzionális online jelenlétre {cityData.nameIn}.
        </p>
        <ul>
          <li>Kis- és középvállalkozások – bemutatkozó oldalak és webshopok</li>
          <li>Startupok – gyors prototípus és MVP fejlesztés</li>
          <li>Egyéni vállalkozók – portfólió és landing page</li>
          <li>Helyi szolgáltatók – lokális SEO optimalizálással</li>
        </ul>

        <h2>Honlapkészítés {cityData.name} – folyamat és határidők</h2>
        <p>
          A munkafolyamat átlátható és ügyfélközpontú. Először egy ingyenes konzultáción
          megismerjük egymást és az igényeidet, majd ajánlatot küldök. Egy átlagos
          bemutatkozó oldal <strong>1–2 hét alatt</strong> elkészül, míg egy komplexebb
          webshopnál 3–6 héttel kell számolni.
        </p>
        <p>
          Nem kell {cityData.nameIn} lenned ahhoz, hogy velem dolgozz – teljesen online,
          videóhíváson és emailen keresztül is gördülékenyen megy az együttműködés.
          De ha {cityData.nameIn} vagy és személyesen is szeretnél találkozni, azt is
          meg tudjuk szervezni.
        </p>

        <!-- FAQ section -->
        <h2>Gyakori kérdések – Honlapkészítés {cityData.name}</h2>
        <div style="margin-top:1.5rem;">
          <div style="background:var(--bg-card);border:1.5px solid var(--border);border-radius:var(--radius);padding:1.25rem 1.5rem;margin-bottom:1rem;">
            <strong style="color:var(--text);display:block;margin-bottom:0.5rem;">Mennyibe kerül egy weboldal {cityData.nameIn}?</strong>
            <p style="margin:0;font-size:0.92rem;">Egy bemutatkozó weboldal 120 000 Ft-tól, üzleti weboldal 280 000 Ft-tól, webshop 450 000 Ft-tól indul. Az ingyenes konzultáción pontosítjuk az igényeid alapján.</p>
          </div>
          <div style="background:var(--bg-card);border:1.5px solid var(--border);border-radius:var(--radius);padding:1.25rem 1.5rem;margin-bottom:1rem;">
            <strong style="color:var(--text);display:block;margin-bottom:0.5rem;">Mennyi idő alatt készül el a weboldal?</strong>
            <p style="margin:0;font-size:0.92rem;">Egy átlagos bemutatkozó oldal 1–2 hét alatt elkészül. Komplexebb webshopnál 3–6 héttel kell számolni. A pontos határidőt az ingyenes konzultáción egyeztetjük.</p>
          </div>
          <div style="background:var(--bg-card);border:1.5px solid var(--border);border-radius:var(--radius);padding:1.25rem 1.5rem;">
            <strong style="color:var(--text);display:block;margin-bottom:0.5rem;">Kell találkozni személyesen {cityData.nameIn}?</strong>
            <p style="margin:0;font-size:0.92rem;">Nem kötelező – az együttműködés teljesen online is gördülékenyen működik. Ha mégis szeretnél személyes találkozót, azt szívesen megszervezzük.</p>
          </div>
        </div>

        <div class="city-cta">
          <h2>Kész vagy az online jelenléted fejlesztésére {cityData.nameIn}?</h2>
          <p>
            Vedd fel velem a kapcsolatot egy ingyenes, kötelezettségmentes konzultációért.
            Együtt megbeszéljük az igényeidet és azt, hogyan tudok legjobban segíteni.
          </p>
          <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
            <a href="/#contact" class="btn btn-primary">Ingyenes konzultáció kérése →</a>
            <a href="/arak/" class="btn btn-outline">Árak megtekintése</a>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
